    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@radix-ui/react-switch": "^1.2.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.7.0",
    "react-router-dom": "^7.13.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "4.1.12",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.edu.app",
